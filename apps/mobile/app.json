{
  "expo": {
    "name": "Projection Mapper Remote",
    "slug": "projection-mapper-remote",
    "version": "0.16.10",
    "orientation": "portrait",
    "scheme": "projmapper",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f19"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.obi811.projectionmapper.remote",
      "infoPlist": {
        "NSCameraUsageDescription": "Die Kamera wird benötigt, um den QR-Code zur Kopplung mit der Desktop-App zu scannen.",
        "NSLocalNetworkUsageDescription": "Die Verbindung zur Desktop-App erfolgt über das lokale Netzwerk."
      }
    },
    "android": {
      "package": "com.obi811.projectionmapper.remote",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f19"
      },
      "permissions": [
        "CAMERA",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Die Kamera wird benötigt, um den QR-Code zur Kopplung mit der Desktop-App zu scannen."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://licensing.obitron.de"
    }
  }
}
